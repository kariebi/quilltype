{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quilltype.dev/schemas/quilltype.schema.json",
  "title": "Quill Type Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "outputs"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireOperationIds": {
          "type": "boolean"
        },
        "requireResponseSchemas": {
          "type": "boolean"
        }
      }
    },
    "breaking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["against"],
      "properties": {
        "against": {
          "$ref": "#/$defs/source"
        },
        "includeWarnings": {
          "type": "boolean"
        },
        "report": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": {
              "type": "string",
              "enum": ["text", "json", "markdown"]
            },
            "output": {
              "type": "string"
            }
          }
        }
      }
    },
    "watch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pollIntervalMs": {
          "type": "integer",
          "minimum": 1
        },
        "retryDelayMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "oneOf": [
        {
          "required": ["path"]
        },
        {
          "required": ["url"]
        }
      ]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mode"],
      "properties": {
        "path": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "types",
            "fetch-client",
            "react-query",
            "axios-client",
            "swr",
            "zod",
            "json-schema"
          ]
        }
      }
    }
  }
}
