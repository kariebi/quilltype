{
  "$schema": "../../schemas/typebridge.schema.json",
  "source": {
    "url": "http://127.0.0.1:8010/openapi.json"
  },
  "outputs": [
    {
      "path": "./frontend/generated/api-types.ts",
      "mode": "types"
    },
    {
      "path": "./frontend/generated/api-react-query.ts",
      "mode": "react-query"
    }
  ],
  "validation": {
    "requireOperationIds": true,
    "requireResponseSchemas": true
  },
  "watch": {
    "pollIntervalMs": 5000,
    "retryDelayMs": 1000
  }
}
