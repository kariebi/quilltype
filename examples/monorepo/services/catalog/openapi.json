{
  "openapi": "3.0.3",
  "info": {
    "title": "Catalog Service",
    "version": "1.0.0"
  },
  "paths": {
    "/catalog/items": {
      "get": {
        "operationId": "listCatalogItems",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CatalogItem"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CatalogItem": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
